PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/myapp
JWT_SECRET=change_this_secret

# Optional legacy OCR bridge
EXTERNAL_OCR_URL=https://your-ocr-provider-endpoint
EXTERNAL_OCR_API_KEY=your_api_key_here

# Primary AI extractors
GOOGLE_DOCUMENT_AI_PROJECT_ID=your-gcp-project-id
GOOGLE_DOCUMENT_AI_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=your_document_ai_processor_id
GOOGLE_DOCUMENT_AI_PROCESSOR_VERSION=
GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account.json

OPENAI_API_KEY=your_openai_api_key_here
UNLOADING_OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=your_gemini_api_key_here
UNLOADING_GEMINI_MODEL=gemini-2.5-flash

# Fallback AI extractor
GROQ_API_KEY=your_groq_api_key_here
UNLOADING_DOCUMENT_AI_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
UNLOADING_DOCUMENT_AI_ATTEMPTS=2
UNLOADING_ENABLE_VISION_REVIEW=1

# Local OCR fallback
DEBUG_UNLOADING_CROPS=0
UNLOADING_OCR_SCRIPT_PATH=ocr/unloading_easyocr_reader.py

